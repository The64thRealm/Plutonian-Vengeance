--- !u!114 &407437220
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 407437217}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5b3b7878b8977f04f9733c845259b18d, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  lines:
  - text: The silence of space is deafening...
    alternateTextAdvanceEvent: {fileID: 0}
  - text: ...
    alternateTextAdvanceEvent: {fileID: 0}
  - text: 'Space calls out to you and says:'
    alternateTextAdvanceEvent: {fileID: 0}
  - text: '"WASD or Left Joystick to move"'
    alternateTextAdvanceEvent: {fileID: 0}
  - text: 'Space follows up with:'
    alternateTextAdvanceEvent: {fileID: 0}
  - text: '"Hold Space or the bottom controller button to capture the bright asteroids,
      and release to... release"'
    alternateTextAdvanceEvent: {fileID: 11400000, guid: c48d56e2c25f91c45b24460933f4fb79, type: 2}
  - text: '"... Move in small circles in the correct direction to make it go fast"'
    alternateTextAdvanceEvent: {fileID: 11400000, guid: 6327e40d8ed62454c91363b86c3a5592, type: 2}
  - text: '"... Release to launch the asteroid to do damage. Faster asteroids do
      much more damage."'
    alternateTextAdvanceEvent: {fileID: 0}
  - text: '"Try attacking that moon in the center."'
    alternateTextAdvanceEvent: {fileID: 11400000, guid: 3237e6355d654d949a4745889641aad9, type: 2}
  - text: '"Nicely done"'
    alternateTextAdvanceEvent: {fileID: 0}
  - text: '"You won''t be able to hold asteroids in orbit for too long, so make sure
      to grab and launch fast"'
    alternateTextAdvanceEvent: {fileID: 0}
  - text: '"The universe is a cruel, unforgiving place... So remember that objects
      headed towards you prooobably have some malicious intent."'
    alternateTextAdvanceEvent: {fileID: 0}
  - text: ...
    alternateTextAdvanceEvent: {fileID: 0}
  - text: Don't get hurt out there, Pluto
    alternateTextAdvanceEvent: {fileID: 0}
  - text: A piercing blue light shines from a distance... Beware...
    alternateTextAdvanceEvent: {fileID: 0}
  DialogueFinished:
    m_PersistentCalls:
      m_Calls:
      - m_Target: {fileID: 1493556086}
        m_TargetAssemblyTypeName: UnityEngine.Behaviour, UnityEngine
        m_MethodName: set_enabled
        m_Mode: 6
        m_Arguments:
          m_ObjectArgument: {fileID: 0}
          m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
          m_IntArgument: 0
